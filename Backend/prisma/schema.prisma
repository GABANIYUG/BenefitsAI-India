generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id // Firebase UID
  email         String?   @unique
  phone         String?   @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profiles      Profile[]
  sessions      ChatSession[]
  applications  Application[]
  savedSchemes  SavedScheme[]
  auditLogs     AuditLog[]
}

enum Role {
  USER
  ADMIN
}

model Profile {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relation        String   @default("self") 
  
  age             Int?
  gender          String?
  state           String?
  district        String?
  income          Float?
  casteCategory   String?  
  occupation      String?
  isStudent       Boolean  @default(false)
  isFarmer        Boolean  @default(false)
  hasDisability   Boolean  @default(false)
  maritalStatus   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SchemeCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  schemes     Scheme[]
}

model Scheme {
  id               String   @id @default(uuid())
  categoryId       String
  category         SchemeCategory @relation(fields: [categoryId], references: [id])
  
  title            String
  description      String
  state            String?  
  ministry         String?
  benefits         Json     
  applicationUrl   String?
  
  eligibilityRules Json     
  qdrantId         String?  @unique
  
  isActive         Boolean  @default(true)
  expiryDate       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents        SchemeDocument[]
  savedBy          SavedScheme[]
  applications     Application[]
}

model SchemeDocument {
  id          String  @id @default(uuid())
  schemeId    String
  scheme      Scheme  @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isRequired  Boolean @default(true)
}

model ChatSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user or assistant
  content   String
  createdAt DateTime @default(now())
}

model SavedScheme {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeId  String
  scheme    Scheme   @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, schemeId])
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeId  String
  scheme    Scheme   @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  status    String   @default("draft") // draft, submitted, approved, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  resource  String
  details   Json?
  createdAt DateTime @default(now())
}
